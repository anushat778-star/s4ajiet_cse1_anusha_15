public class SmallestNumber {
    public static void main(String[] args) {
        int[] arr = {10, 25, 5, 78, 30};

        int min = arr[0];  // assume first element is smallest

        for (int i = 1; i < arr.length; i++) {
            if (arr[i] < min) {
                min = arr[i];
            }
        }

        System.out.println("Smallest number is: " + min);
    }
}
