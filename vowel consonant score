class Solution {
    public int vowelConsonantScore(String s) {
        int v = 0, c = 0;

        for (char ch : s.toCharArray()) {
            if (Character.isLetter(ch)) {
                ch = Character.toLowerCase(ch);

                if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u') {
                    v++;
                } else {
                    c++;
                }
            }
        }

        return (c > 0) ? (v / c) : 0;
    }
}
