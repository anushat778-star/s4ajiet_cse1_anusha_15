public class Main {
    public static void main(String[] args) {
        String input = "hello world java";

        StringBuilder sb = new StringBuilder();

        for (char ch : input.toCharArray()) {
            if (!Character.isWhitespace(ch)) {
                sb.append(ch);
            }
        }

        System.out.println(sb.toString());
    }
}


